#!/usr/bin/env sh
set -eu
INVOKED_PATH=$0
case "$INVOKED_PATH" in
  */*) ;;
  *)
    RESOLVED_COMMAND=$(command -v "$INVOKED_PATH" 2>/dev/null || true)
    if [ -n "$RESOLVED_COMMAND" ]; then
      INVOKED_PATH=$RESOLVED_COMMAND
    fi
    ;;
esac
case "$INVOKED_PATH" in
  /*) ;;
  *)
    INVOKED_DIR=$(CDPATH= cd -- "$(dirname -- "$INVOKED_PATH")" && pwd)
    INVOKED_PATH=$INVOKED_DIR/$(basename -- "$INVOKED_PATH")
    ;;
esac
export LLREVIEW_INVOKED_PATH=$INVOKED_PATH
SCRIPT_PATH=$0
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
  LINK_TARGET=$(readlink "$SCRIPT_PATH")
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH=$LINK_TARGET ;;
    *) SCRIPT_PATH=$SCRIPT_DIR/$LINK_TARGET ;;
  esac
done
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
exec python3 "$SCRIPT_DIR/scripts/llreview.py" "$@"
