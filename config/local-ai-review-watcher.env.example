# Copy this file to:
#   ~/.config/local-ai-review-watcher/env
#
# Then set owner-only permissions:
#   chmod 600 ~/.config/local-ai-review-watcher/env
#
# Values already present in the process environment take precedence over this file.

WATCH_REPOS=mt4110/local-ai-review
WATCH_WORKFLOW_FILE=local-llm-review.yml
WATCH_LABEL=local-ai-review
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3-coder:30b-a3b-q4_K_M
OLLAMA_WAKE_METHOD=open
OLLAMA_APP_NAME=Ollama
HOMEBREW_BIN=/opt/homebrew/bin/brew
OLLAMA_WAKE_TIMEOUT_SECONDS=30
WATCHER_HTTP_TIMEOUT_SECONDS=5

DISCORD_PUBLIC_KEY=
DISCORD_ALLOWED_USER_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_ALLOWED_COMMANDS=status,wake-if-down
DISCORD_TIMESTAMP_SKEW_SECONDS=300
DISCORD_INTERACTIONS_HOST=127.0.0.1
DISCORD_INTERACTIONS_PORT=8089
DISCORD_EPHEMERAL=true
