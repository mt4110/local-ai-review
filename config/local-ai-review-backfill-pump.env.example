# Copy this file to:
#   ~/.config/local-ai-review-backfill-pump/env
#
# Then set owner-only permissions:
#   chmod 600 ~/.config/local-ai-review-backfill-pump/env
#
# Values already present in the process environment take precedence over this file.

# Default is report-only. It writes pump artifacts but does not import external
# review evidence. Use dry-run for the first scheduled preview, then import-one
# only after the queue behavior looks right.
LLREVIEW_BACKFILL_PUMP_MODE=report
# LLREVIEW_BACKFILL_PUMP_MODE=dry-run
# LLREVIEW_BACKFILL_PUMP_MODE=import-one

LLREVIEW_BACKFILL_PUMP_OWNER=mt4110
LLREVIEW_BACKFILL_PUMP_DB=/Users/YOU/dev/local-ai-review/out/review-history/local-ai-review.db
LLREVIEW_BACKFILL_PUMP_OUTPUT_DIR=/Users/YOU/dev/local-ai-review/out/review-history/backfill-pump
LLREVIEW_BACKFILL_PUMP_LOCK_FILE=/Users/YOU/dev/local-ai-review/out/review-history/backfill-pump.scheduler.lock

# Keep the scheduled lane deliberately slow. The command itself also enforces
# the 20-minute remote import gate.
LLREVIEW_BACKFILL_PUMP_MIN_INTERVAL_MINUTES=20
LLREVIEW_BACKFILL_PUMP_RETRY_DELAY_MINUTES=60

# Queue refresh is a write to the ledger. Leave it off for normal scheduled
# import-one runs unless you deliberately want the scheduler to refresh first.
LLREVIEW_BACKFILL_PUMP_REFRESH_QUEUE=0
LLREVIEW_BACKFILL_PUMP_QUEUE_LIMIT=12

# Scheduled operation defaults to remote GitHub PR review comments only. Top-level
# PR conversation comments are broader and should be enabled only for a deliberate
# local evidence pass.
LLREVIEW_BACKFILL_PUMP_INCLUDE_ISSUE_COMMENTS=0
LLREVIEW_BACKFILL_PUMP_ALLOW_LOCAL_SCAN=0

# Notifications are quiet: only failures or meaningful import milestones.
LLREVIEW_BACKFILL_PUMP_NOTIFY=1
LLREVIEW_BACKFILL_PUMP_NOTIFY_SOUND=

GITHUB_TOKEN=
